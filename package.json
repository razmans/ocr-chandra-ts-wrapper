{
  "name": "chandra-ts",
  "version": "0.1.0",
  "description": "TypeScript SDK/client for Chandra OCR with optional local managed runtime tools.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chandra-ts": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "bridge",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "setup:local": "npm run build && node scripts/setup-local-runtime.mjs",
    "doctor": "npm run build && node dist/cli/index.js doctor",
    "warmup": "npm run build && node dist/cli/index.js warmup"
  },
  "keywords": [
    "ocr",
    "chandra",
    "typescript",
    "pdf",
    "markdown",
    "html"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
